{
  "schemaVersion": 1,
  "manifest": {
    "manifestVersion": 1,
    "id": "core.git-ops",
    "packageName": "@mdwrk/extension-git-ops",
    "version": "1.0.1",
    "displayName": {
      "defaultMessage": "Git Operations"
    },
    "description": {
      "defaultMessage": "Git tools for repos and settings."
    },
    "kind": "bundled",
    "icon": {
      "kind": "lucide",
      "name": "GitBranch"
    },
    "enabledByDefault": true,
    "capabilities": [
      "view.register",
      "actionRail.register",
      "settings.read",
      "settings.write",
      "notification.publish",
      "workspace.read",
      "network.fetch"
    ],
    "capabilityPresetIds": [
      "workspace.module.provider",
      "workspace.module.diagnostics"
    ],
    "compatibility": {
      "manifestVersion": 1,
      "hostApi": "^1.0.0",
      "runtime": "^1.0.0",
      "app": ">=1.4.21",
      "themeContract": "^1.0.0"
    },
    "entry": {
      "module": "./index.js",
      "export": "createGitOpsBundledEntry"
    },
    "i18n": {
      "defaultLocale": "en",
      "supportedLocales": [
        "en"
      ]
    },
    "contributions": {
      "commands": [
        {
          "id": "core.toggle-git-pane",
          "title": {
            "defaultMessage": "Toggle Git Operations",
            "key": "core.commands.toggle-git-pane"
          },
          "icon": {
            "kind": "lucide",
            "name": "GitBranch"
          }
        },
        {
          "id": "core.git-ops.refresh",
          "title": {
            "defaultMessage": "Refresh Git Operations"
          },
          "icon": {
            "kind": "lucide",
            "name": "RefreshCw"
          }
        }
      ],
      "views": [
        {
          "id": "core.git-pane",
          "title": {
            "defaultMessage": "Git Operations",
            "key": "core.views.git.title"
          },
          "description": {
            "defaultMessage": "Source control workspace.",
            "key": "core.views.git.description"
          },
          "icon": {
            "kind": "lucide",
            "name": "GitBranch"
          },
          "location": "main",
          "allowMultiple": false,
          "canBePinned": true
        },
        {
          "id": "core.git-ops.explorer",
          "title": {
            "defaultMessage": "Git Explorer"
          },
          "description": {
            "defaultMessage": "Branches and file changes."
          },
          "icon": {
            "kind": "lucide",
            "name": "GitBranch"
          },
          "location": "sidebar",
          "allowMultiple": false,
          "canBePinned": true
        }
      ],
      "components": [],
      "workspaceModules": [
        {
          "id": "core.git-ops.module",
          "title": {
            "defaultMessage": "Git Operations"
          },
          "description": {
            "defaultMessage": "Git view, diffs, and repo actions."
          },
          "icon": {
            "kind": "lucide",
            "name": "GitBranch"
          },
          "primaryViewId": "core.git-pane",
          "explorerViewId": "core.git-ops.explorer",
          "supportedLayouts": [
            "single",
            "left",
            "right",
            "split"

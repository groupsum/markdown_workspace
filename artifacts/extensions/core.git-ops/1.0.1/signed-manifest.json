      "title": {
        "defaultMessage": "Source Control",
        "key": "core.settings.sections.git.title"
      },
      "description": {
        "defaultMessage": "Repository and identity settings.",
        "key": "core.settings.sections.git.description"
      },
      "sections": [],
      "fields": []
    }

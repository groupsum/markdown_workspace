{
  "manifestVersion": 1,
  "id": "core.gemini-agent",
  "packageName": "@mdwrk/extension-gemini-agent",
  "version": "1.1.1",
  "displayName": {
    "key": "core.gemini-agent.manifest.displayName",
    "defaultMessage": "Gemini Agent"
  },
  "description": {
    "key": "core.gemini-agent.manifest.description",
    "defaultMessage": "Bundled Gemini assistant for summarizing files, drafting selection rewrites, and staging safe writeback operations."
  },
  "kind": "bundled",
  "publisher": "Markdown Workspace",
  "license": "Apache-2.0",
  "categories": [
    "ai",
    "assistant",
    "workflow"
  ],
  "keywords": [
    "gemini",
    "assistant",
    "markdown",
    "rewrite",
    "summary"
  ],
  "icon": {
    "kind": "lucide",
    "name": "Bot"
  },
  "enabledByDefault": true,
  "capabilities": [
    "workspace.read",
    "editor.read",
    "editor.write",
    "selection.read",
    "settings.read",
    "settings.write",
    "notification.publish",
    "command.invoke",
    "actionRail.register",
    "view.register",
    "network.fetch"
  ],
  "compatibility": {
    "manifestVersion": 1,
    "hostApi": "^1.0.0",
    "runtime": "^1.0.0",
    "app": ">=1.3.49",
    "themeContract": "^1.0.0",
    "renderer": "^1.0.0",
    "editor": "^1.0.0"
  },
  "entry": {
    "module": "./createGeminiAgentBundledEntry.js",
    "export": "createGeminiAgentBundledEntry"
  },
  "contributions": {
    "commands": [
      {
        "id": "core.gemini-agent.open",
        "title": {
          "key": "core.gemini-agent.commands.open.title",
          "defaultMessage": "Open Gemini Agent"
        },
        "description": {
          "key": "core.gemini-agent.commands.open.description",
          "defaultMessage": "Open the Gemini Agent operator view."
        },
        "icon": {
          "kind": "lucide",
          "name": "Bot"
        },
        "keywords": [
          "gemini",
          "agent",
          "assistant"
        ]
      },
      {
        "id": "core.gemini-agent.summarize-current-file",
        "title": {
          "key": "core.gemini-agent.commands.summarize.title",
          "defaultMessage": "Summarize Current File"
        },
        "description": {
          "key": "core.gemini-agent.commands.summarize.description",
          "defaultMessage": "Summarize the active markdown document in the Gemini Agent view."
        },
        "icon": {
          "kind": "lucide",
          "name": "FileText"
        },
        "keywords": [
          "gemini",
          "summary",
          "document",
          "markdown"
        ]
      },
      {
        "id": "core.gemini-agent.rewrite-selection",
        "title": {
          "key": "core.gemini-agent.commands.rewrite.title",
          "defaultMessage": "Draft Rewrite of Selection"
        },
        "description": {
          "key": "core.gemini-agent.commands.rewrite.description",
          "defaultMessage": "Generate a draft rewrite for the current selection in the Gemini Agent view."
        },
        "icon": {
          "kind": "lucide",
          "name": "Pencil"
        },
        "keywords": [
          "gemini",
          "rewrite",
          "selection",
          "draft"
        ]
      },
      {
        "id": "core.gemini-agent.apply-draft-to-selection",
        "title": {
          "key": "core.gemini-agent.commands.applySelection.title",
          "defaultMessage": "Apply Gemini Draft to Selection"
        },
        "description": {
          "key": "core.gemini-agent.commands.applySelection.description",
          "defaultMessage": "Apply the current Gemini draft to the active selection when writeback is enabled."
        },
        "icon": {
          "kind": "lucide",
          "name": "Save"
        },
        "keywords": [
          "gemini",
          "apply",
          "selection",
          "draft"
        ]
      },
      {
        "id": "core.gemini-agent.replace-document-with-draft",
        "title": {
          "key": "core.gemini-agent.commands.replaceDocument.title",
          "defaultMessage": "Replace Document With Gemini Draft"
        },
        "description": {
          "key": "core.gemini-agent.commands.replaceDocument.description",
          "defaultMessage": "Replace the current document with the latest Gemini draft when writeback is enabled."
        },
        "icon": {
          "kind": "lucide",
          "name": "Save"
        },
        "keywords": [
          "gemini",
          "replace",
          "document",
          "draft"
        ]
      }
    ],
    "views": [
      {
        "id": "core.gemini-agent.view",
        "title": {
          "key": "core.gemini-agent.view.title",
          "defaultMessage": "Gemini Agent"
        },
        "description": {
          "key": "core.gemini-agent.view.description",
          "defaultMessage": "Run Gemini workflows against the active markdown document and manage safe draft writeback."
        },
        "icon": {
          "kind": "lucide",
          "name": "Bot"
        },
        "location": "modal",
        "allowMultiple": false,
        "canBePinned": false
      }
    ],
    "components": [],
    "actionRail": [
      {
        "id": "core.gemini-agent.rail",
        "title": {
          "key": "core.gemini-agent.rail.title",
          "defaultMessage": "Gemini"
        },
        "icon": {
          "kind": "lucide",
          "name": "Bot"
        },
        "group": "assistant",
        "order": 10,
        "target": {
          "kind": "view",
          "viewId": "core.gemini-agent.view"
        }
      }
    ],
    "settingsSections": [
      {
        "id": "core.gemini-agent.settings",
        "title": {
          "key": "core.gemini-agent.settings.title",
          "defaultMessage": "Gemini Agent settings"
        },
        "description": {
          "key": "core.gemini-agent.settings.description",
          "defaultMessage": "Configure provider connectivity, automatic context attachment, and safe writeback behavior for the Gemini extension."
        },
        "order": 10,
        "schemaPath": "manifest.settingsSchema"
      }
    ]
  },
  "settingsSchema": {
    "version": 1,
    "title": {
      "key": "core.gemini-agent.settings.title",
      "defaultMessage": "Gemini Agent settings"
    },
    "description": {
      "key": "core.gemini-agent.settings.description",
      "defaultMessage": "Configure provider connectivity, automatic context attachment, and safe writeback behavior for the Gemini extension."
    },
    "sections": [
      {
        "id": "core.gemini-agent.settings.general",
        "title": {
          "key": "core.gemini-agent.settings.sections.general.title",
          "defaultMessage": "Provider"
        },
        "description": {
          "key": "core.gemini-agent.settings.sections.general.description",
          "defaultMessage": "Configure the Gemini endpoint, model selection, authentication, and request behavior."
        }
      },
      {
        "id": "core.gemini-agent.settings.context",
        "title": {
          "key": "core.gemini-agent.settings.sections.context.title",
          "defaultMessage": "Context"
        },
        "description": {
          "key": "core.gemini-agent.settings.sections.context.description",
          "defaultMessage": "Control how the active document and current selection are attached to ad hoc prompts."
        }
      },
      {
        "id": "core.gemini-agent.settings.writeback",
        "title": {
          "key": "core.gemini-agent.settings.sections.writeback.title",
          "defaultMessage": "Writeback"
        },
        "description": {
          "key": "core.gemini-agent.settings.sections.writeback.description",
          "defaultMessage": "Control whether Gemini drafts can be explicitly applied back into the editor."
        }
      }
    ],
    "fields": [
      {
        "key": "endpoint",
        "kind": "string",
        "sectionId": "core.gemini-agent.settings.general",
        "label": {
          "key": "core.gemini-agent.settings.fields.endpoint.label",
          "defaultMessage": "API endpoint"
        },
        "description": {
          "key": "core.gemini-agent.settings.fields.endpoint.description",
          "defaultMessage": "Base Gemini API endpoint or a full generateContent URL."
        },
        "defaultValue": "https://generativelanguage.googleapis.com/v1beta",
        "placeholder": "https://generativelanguage.googleapis.com/v1beta"
      },
      {
        "key": "model",
        "kind": "string",
        "sectionId": "core.gemini-agent.settings.general",
        "label": {
          "key": "core.gemini-agent.settings.fields.model.label",
          "defaultMessage": "Model"
        },
        "description": {
          "key": "core.gemini-agent.settings.fields.model.description",
          "defaultMessage": "Gemini model name used for generateContent requests."
        },
        "defaultValue": "gemini-2.5-flash"
      },
      {
        "key": "authMode",
        "kind": "select",
        "sectionId": "core.gemini-agent.settings.general",
        "label": {
          "key": "core.gemini-agent.settings.fields.authMode.label",
          "defaultMessage": "Authentication mode"
        },
        "description": {
          "key": "core.gemini-agent.settings.fields.authMode.description",
          "defaultMessage": "Use an API key directly or route requests through an upstream that handles authentication."
        },
        "defaultValue": "api-key",
        "options": [
          {
            "value": "api-key",
            "label": {
              "key": "core.gemini-agent.settings.fields.authMode.option.apiKey",
              "defaultMessage": "API key"
            }
          },
          {
            "value": "none",
            "label": {
              "key": "core.gemini-agent.settings.fields.authMode.option.none",
              "defaultMessage": "No direct auth in extension"
            }
          }
        ]
      },
      {
        "key": "apiKey",
        "kind": "secret",
        "sectionId": "core.gemini-agent.settings.general",
        "label": {
          "key": "core.gemini-agent.settings.fields.apiKey.label",
          "defaultMessage": "API key"
        },
        "description": {
          "key": "core.gemini-agent.settings.fields.apiKey.description",
          "defaultMessage": "Gemini API key used when authentication mode is set to API key."
        },
        "defaultValue": ""
      },
      {
        "key": "systemPrompt",
        "kind": "string",
        "sectionId": "core.gemini-agent.settings.general",
        "label": {
          "key": "core.gemini-agent.settings.fields.systemPrompt.label",
          "defaultMessage": "System prompt"
        },
        "description": {
          "key": "core.gemini-agent.settings.fields.systemPrompt.description",
          "defaultMessage": "Instruction prepended to every Gemini request."
        },
        "defaultValue": "You are an expert markdown copilot. Preserve markdown structure unless the user explicitly asks for a format change.",
        "multiline": true
      },
      {
        "key": "temperature",
        "kind": "number",
        "sectionId": "core.gemini-agent.settings.general",
        "label": {
          "key": "core.gemini-agent.settings.fields.temperature.label",
          "defaultMessage": "Temperature"
        },
        "description": {
          "key": "core.gemini-agent.settings.fields.temperature.description",
          "defaultMessage": "Sampling temperature passed to Gemini."
        },
        "defaultValue": 0.2,
        "min": 0,
        "max": 2,
        "step": 0.1
      },
      {
        "key": "requestTimeoutMs",
        "kind": "integer",
        "sectionId": "core.gemini-agent.settings.general",
        "label": {
          "key": "core.gemini-agent.settings.fields.timeout.label",
          "defaultMessage": "Request timeout (ms)"
        },
        "description": {
          "key": "core.gemini-agent.settings.fields.timeout.description",
          "defaultMessage": "Abort the Gemini request if it exceeds this duration."
        },
        "defaultValue": 30000,
        "min": 1000,
        "max": 300000,
        "step": 1000
      },
      {
        "key": "autoAttachDocument",
        "kind": "boolean",
        "sectionId": "core.gemini-agent.settings.context",
        "label": {
          "key": "core.gemini-agent.settings.fields.autoAttachDocument.label",
          "defaultMessage": "Attach active document to custom prompts"
        },
        "description": {
          "key": "core.gemini-agent.settings.fields.autoAttachDocument.description",
          "defaultMessage": "Include the current markdown document when using the custom prompt workflow."
        },
        "defaultValue": true
      },
      {
        "key": "autoAttachSelection",
        "kind": "boolean",
        "sectionId": "core.gemini-agent.settings.context",
        "label": {
          "key": "core.gemini-agent.settings.fields.autoAttachSelection.label",
          "defaultMessage": "Attach current selection to custom prompts"
        },
        "description": {
          "key": "core.gemini-agent.settings.fields.autoAttachSelection.description",
          "defaultMessage": "Include the current selection when using the custom prompt workflow."
        },
        "defaultValue": true
      },
      {
        "key": "allowWriteBack",
        "kind": "boolean",
        "sectionId": "core.gemini-agent.settings.writeback",
        "label": {
          "key": "core.gemini-agent.settings.fields.allowWriteBack.label",
          "defaultMessage": "Allow explicit writeback"
        },
        "description": {
          "key": "core.gemini-agent.settings.fields.allowWriteBack.description",
          "defaultMessage": "Permit the Apply actions to write Gemini drafts into the editor. Disabled by default for safety."
        },
        "defaultValue": false
      }
    ]
  },
  "i18n": {
    "defaultLocale": "en",
    "supportedLocales": [
      "en",
      "es"
    ]
  },
  "distribution": {
    "channel": "bundled",
    "format": "esm"
  },
  "support": {
    "owner": "Markdown Workspace",
    "status": "active",
    "level": "official"
  }
}

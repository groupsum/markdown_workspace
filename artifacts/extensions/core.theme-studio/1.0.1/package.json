{
  "name": "@mdwrk/extension-theme-studio",
  "version": "1.0.1",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": [
    "markdown-workspace",
    "extension",
    "theme",
    "studio",
    "tokens"
  ],
  "description": "First-party theme authoring extension for Markdown Workspace with token inspection, live renderer/editor previews, apply/revert flow, and export helpers.",
  "dependencies": {
    "@mdwrk/extension-host": "^1.0.1",
    "@mdwrk/extension-manifest": "^1.0.0",
    "@mdwrk/extension-runtime": "^1.0.1",
    "@mdwrk/theme-contract": "^1.0.0",
    "@mdwrk/ui-tokens": "^1.0.1",
    "@mdwrk/markdown-renderer-react": "^1.0.1",
    "@mdwrk/markdown-editor-react": "^1.0.2",
    "lucide-react": "^0.475.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "scripts": {
    "build:deps": "npm run build -w @mdwrk/extension-manifest && npm run build -w @mdwrk/extension-host && npm run build -w @mdwrk/theme-contract && npm run build -w @mdwrk/ui-tokens && npm run build -w @mdwrk/markdown-renderer-react && npm run build -w @mdwrk/markdown-editor-react && npm run build -w @mdwrk/extension-runtime",
    "build": "npm run build:deps && tsc -p tsconfig.json",
    "typecheck": "npm run build:deps && tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "npm run build && node ./tests/run-smoke.mjs",
    "prepack": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./settings": {
      "types": "./dist/settings.d.ts",
      "import": "./dist/settings.js"
    },
    "./service": {
      "types": "./dist/service.d.ts",
      "import": "./dist/service.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./exports": {
      "types": "./dist/export.d.ts",
      "import": "./dist/export.js"
    },
    "./relationships": {
      "types": "./dist/relationship.d.ts",
      "import": "./dist/relationship.js"
    },
    "./bundled": {
      "types": "./dist/createThemeStudioBundledEntry.d.ts",
      "import": "./dist/createThemeStudioBundledEntry.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com",
  "browserInstallable": false,
  "bundledBy": "tools/extensions/build-installable-extensions.mjs"
}

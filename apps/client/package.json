{
  "name": "@mdwrk/mdwrkspace",
  "private": false,
  "version": "1.4.10",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "tsc && vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "screenshots:matrix": "node ./tests/generate-theme-screenshots.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "prepack": "npm run build:lib"
  },
  "module": "./dist/mdwrkspace.js",
  "exports": {
    ".": {
      "import": "./dist/mdwrkspace.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mdwrk/extension-gemini-agent": "^1.1.1",
    "@mdwrk/extension-host": "^1.0.2",
    "@mdwrk/extension-language-pack-studio": "^1.0.3",
    "@mdwrk/extension-manager": "^1.1.6",
    "@mdwrk/extension-manifest": "^1.0.1",
    "@mdwrk/extension-runtime": "^1.1.3",
    "@mdwrk/i18n": "^1.2.1",
    "@mdwrk/icons": "^1.0.1",
    "@mdwrk/markdown-editor-react": "^1.1.1",
    "@mdwrk/markdown-renderer-core": "^1.1.1",
    "@mdwrk/markdown-renderer-react": "^1.1.1",
    "@mdwrk/theme-contract": "^1.1.1",
    "@mdwrk/ui-tokens": "^1.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-syntax-highlighter": "^15.6.1",
    "@mdwrk/extension-theme-studio": "^1.1.5"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.4.1",
    "vitest": "^2.1.8"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10"
  },
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com"
}

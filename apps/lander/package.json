{
  "name": "@mdwrk/lander",
  "private": true,
  "version": "0.0.30",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:deps": "npm --prefix ../.. run build:editor",
    "validate:article-metadata": "node ./scripts/validate-article-metadata.mjs",
    "validate:answer-block-layout": "node ./scripts/validate-answer-block-layout.mjs",
    "validate:syntax-themes": "node ./scripts/validate-syntax-themes.mjs",
    "build": "npm run build:deps && npm run validate:article-metadata && npm run validate:answer-block-layout && npm run validate:syntax-themes && node ./scripts/generate-sitemap.mjs && vite build",
    "preview": "vite preview",
    "typecheck": "npm run build:deps && npm run validate:article-metadata && npm run validate:answer-block-layout && npm run validate:syntax-themes && tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "@mdwrk/markdown-editor-react": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.9.3",
    "lucide-react": "^0.563.0",
    "@mdwrk/markdown-renderer-core": "^1.1.1",
    "@mdwrk/markdown-renderer-react": "^1.1.1",
    "@mdwrk/ui-tokens": "^1.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "license": "Apache-2.0",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com"
}

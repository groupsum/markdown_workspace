{
  "name": "@mdwrk/mdwrkcom",
  "private": true,
  "version": "0.0.54",
  "type": "module",
  "scripts": {
    "mdwrkcom": "node ./src/cli.mjs",
    "generate:markdown-cluster": "node ./scripts/generate-markdown-cluster.mjs",
    "validate:markdown-cluster": "node ./scripts/generate-markdown-cluster.mjs --check",
    "sync:content-pack-generated": "node ./scripts/sync-content-pack-generated.mjs",
    "dev": "vite",
    "build": "npm run build:static:dist",
    "build:styled": "npm run build:deps && npm run validate:article-metadata && npm run validate:article-images && npm run validate:blog-faq && npm run validate:faq-layout && npm run validate:header-content && npm run validate:footer-content && npm run validate:home-content && npm run validate:compare-content && npm run validate:feature-content && npm run validate:syntax-themes && node ./scripts/generate-sitemap.mjs && vite build",
    "build:spa": "npm run build:styled",
    "build:deps": "npm --prefix ../.. run build:editor",
    "validate:article-metadata": "node ./scripts/validate-article-metadata.mjs",
    "validate:article-images": "node ./scripts/validate-article-image-contract.mjs",
    "validate:blog-faq": "node ./scripts/validate-blog-faq-block.mjs",
    "validate:faq-layout": "node ./scripts/validate-faq-layout.mjs",
    "validate:header-content": "node ./scripts/validate-header-content.mjs",
    "validate:footer-content": "node ./scripts/validate-footer-content.mjs",
    "validate:home-content": "node ./scripts/validate-home-content.mjs",
    "validate:compare-content": "node ./scripts/validate-compare-content.mjs",
    "validate:feature-content": "node ./scripts/validate-feature-content.mjs",
    "validate:syntax-themes": "node ./scripts/validate-syntax-themes.mjs",
    "validate:sitemap-xml": "node ./scripts/validate-sitemap-xml.mjs",
    "validate:international-seo": "node ./scripts/validate-international-seo.mjs",
    "validate:discoverability-artifacts": "node ./scripts/validate-discoverability-artifacts.mjs",
    "validate:aeo-content-parity": "node ./scripts/validate-aeo-content-parity.mjs",
    "validate:ai-crawler-policy": "node ./scripts/validate-ai-crawler-policy.mjs",
    "validate:static-first-paint-theme": "node ./scripts/validate-static-first-paint-theme.mjs",
    "verify:static-first-paint-theme": "node ./scripts/validate-static-first-paint-theme.mjs --generated",
    "validate:static-style-contract": "node ./scripts/validate-static-style-contract.mjs",
    "validate:static": "node ./src/cli.mjs validate",
    "test:lander-renderer-host": "node ./tests/run-lander-renderer-host-smoke.mjs",
    "build:static": "node ./src/cli.mjs build --out dist-static",
    "build:static:dist": "node ./src/cli.mjs build --out dist --preserve-assets",
    "verify:static": "node ./src/cli.mjs verify --out dist-static",
    "verify": "node ./src/cli.mjs verify --out dist",
    "clean": "node ./src/cli.mjs clean --out dist && node ./src/cli.mjs clean --out dist-static",
    "ci:static": "npm run validate:static && npm run build:static && npm run verify:static && npm run validate:sitemap-xml -- --out dist-static && npm run validate:international-seo -- --out dist-static && npm run validate:discoverability-artifacts -- --out dist-static && npm run validate:aeo-content-parity -- --out dist-static && npm run validate:ai-crawler-policy -- --out dist-static",
    "ci": "npm run build && npm run verify && npm run ci:static",
    "smoke:deployed": "node ./scripts/post-deploy-smoke.mjs",
    "preview": "vite preview",
    "typecheck": "npm run validate:markdown-cluster && npm run validate:article-metadata && npm run validate:article-images && npm run validate:blog-faq && npm run validate:faq-layout && npm run validate:header-content && npm run validate:footer-content && npm run validate:home-content && npm run validate:compare-content && npm run validate:feature-content && npm run validate:syntax-themes && npm run validate:static-style-contract && npm run validate:static-first-paint-theme && npm run validate:static",
    "lint": "npm run typecheck"
  },
  "dependencies": {
    "@mdwrk/lander-content-contract": "^0.1.0",
    "@mdwrk/lander-core": "^0.1.0",
    "@mdwrk/lander-react": "^0.1.0",
    "@mdwrk/structured-data": "^0.1.1",
    "@mdwrk/lander-seo": "^0.1.0",
    "@mdwrk/lander-theme": "^0.1.2",
    "@mdwrk/markdown-editor-react": "^1.1.0",
    "@mdwrk/markdown-renderer-core": "^1.1.1",
    "@mdwrk/markdown-renderer-react": "^1.1.1",
    "@mdwrk/ui-tokens": "^1.2.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.9.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "ajv": "^8.17.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "license": "Apache-2.0",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com"
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdwrk.com/schemas/mdwrk.page.v1.schema.json",
  "title": "MdWrk static lander page",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "slug",
    "title",
    "description",
    "h1",
    "entity",
    "intent",
    "contentType",
    "updatedAt"
  ],
  "properties": {
    "schema": {
      "const": "mdwrk.page.v1"
    },
    "slug": {
      "type": "string",
      "pattern": "^/[a-z0-9][a-z0-9/-]*/$|^/$"
    },
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "minLength": 40,
      "maxLength": 220
    },
    "h1": {
      "type": "string",
      "minLength": 4,
      "maxLength": 120
    },
    "subtitle": {
      "type": "string",
      "minLength": 20,
      "maxLength": 280
    },
    "entity": {
      "const": "MdWrk"
    },
    "intent": {
      "type": "string",
      "minLength": 4,
      "maxLength": 160
    },
    "contentType": {
      "enum": [
        "landing",
        "feature",
        "docs",
        "update",
        "comparison",
        "package",
        "privacy",
        "security",
        "changelog",
        "faq",
        "glossary"
      ]
    },
    "updatedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "publishedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "featuredImage": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(https?://|/)[^\\s]+$"
    },
    "featuredImageAlt": {
      "type": "string",
      "minLength": 1,
      "maxLength": 180
    },
    "faqs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "answer"],
        "properties": {
          "question": {
            "type": "string",
            "minLength": 8,
            "maxLength": 160
          },
          "answer": {
            "type": "string",
            "minLength": 20,
            "maxLength": 800
          }
        }
      }
    },
    "parent": {
      "type": "string",
      "pattern": "^/[a-z0-9][a-z0-9/-]*/$|^/$"
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^/[a-z0-9][a-z0-9/-]*/$|^/$"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2,
        "maxLength": 40
      }
    },
    "canonical": {
      "type": "string",
      "format": "uri"
    },
    "locale": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$"
    },
    "translationOf": {
      "type": "string",
      "pattern": "^/[a-z0-9][a-z0-9/-]*/$|^/$"
    },
    "localeGroup": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "noindex": {
      "type": "boolean"
    },
    "llmsInclude": {
      "type": "boolean"
    }
  }
}

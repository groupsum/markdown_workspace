{
  "name": "@mdwrk/markdown-editor-core",
  "version": "1.1.7",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": [
    "markdown-workspace",
    "editor",
    "markdown",
    "portable",
    "core"
  ],
  "description": "Portable source-mode markdown editor state, selection transforms, command model, and undo/redo history for MdWrk.",
  "dependencies": {},
  "devDependencies": {
    "@mdwrk/markdown-renderer-core": "^1.1.6",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "node ./tests/prepare-workspace-links.mjs && node ./tests/run-smoke.mjs",
    "prepack": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./class-names": {
      "types": "./dist/class-names.d.ts",
      "import": "./dist/class-names.js"
    },
    "./selection": {
      "types": "./dist/selection.d.ts",
      "import": "./dist/selection.js"
    },
    "./transforms": {
      "types": "./dist/transforms.d.ts",
      "import": "./dist/transforms.js"
    },
    "./commands": {
      "types": "./dist/commands.d.ts",
      "import": "./dist/commands.js"
    },
    "./history": {
      "types": "./dist/history.d.ts",
      "import": "./dist/history.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com"
}

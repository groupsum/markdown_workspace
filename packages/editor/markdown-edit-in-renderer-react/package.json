{
  "name": "@mdwrk/markdown-edit-in-renderer-react",
  "version": "1.0.12",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "dist",
    "src/styles",
    "README.md"
  ],
  "sideEffects": [
    "./src/styles/default.css"
  ],
  "keywords": [
    "markdown-workspace",
    "markdown",
    "editor",
    "renderer",
    "typora",
    "react",
    "deprecated",
    "legacy-bridge",
    "extracted-repo"
  ],
  "description": "Typora-style React editing surface that edits markdown blocks in place inside the rendered document flow for MdWrk.",
  "dependencies": {
    "@mdwrk/markdown-editor-core": "^1.1.7",
    "@mdwrk/markdown-editor-react": "^1.1.7",
    "@mdwrk/markdown-renderer-core": "^1.1.6",
    "@mdwrk/markdown-renderer-react": "^1.1.6",
    "@mdwrk/ui-tokens": "^1.2.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@mdwrk/testing": "^1.0.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.8"
  },
  "scripts": {
    "build:deps": "npm run build -w @mdwrk/markdown-renderer-core && npm run build -w @mdwrk/markdown-renderer-react && npm run build -w @mdwrk/markdown-editor-core && npm run build -w @mdwrk/markdown-editor-react && npm run build -w @mdwrk/ui-tokens",
    "build": "npm run build:deps && tsc -p tsconfig.json",
    "typecheck": "npm run build:deps && tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "node ./tests/prepare-workspace-links.mjs && node ./tests/run-smoke.mjs",
    "prepack": "npm run build",
    "postinstall": "node ../../../tools/release/warn-deprecated-package.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./blocks": {
      "types": "./dist/blocks.d.ts",
      "import": "./dist/blocks.js"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.js"
    },
    "./styles/default.css": "./src/styles/default.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/groupsum/mdwrk",
    "directory": "packages/editor/markdown-edit-in-renderer-react"
  },
  "bugs": {
    "url": "https://github.com/groupsum/mdwrk/issues"
  }
}

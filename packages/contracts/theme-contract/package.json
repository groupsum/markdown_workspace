{
  "version": "1.1.2",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20 <23"
  },
  "keywords": [
    "markdown-workspace",
    "contracts",
    "typescript"
  ],
  "name": "@mdwrk/theme-contract",
  "description": "Portable token and class-name contract for MdWrk themes, renderers, editors, and extensions.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "npm run typecheck",
    "prepack": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./classes": {
      "types": "./dist/classes.d.ts",
      "import": "./dist/classes.js"
    },
    "./compatibility": {
      "types": "./dist/compatibility.d.ts",
      "import": "./dist/compatibility.js"
    },
    "./themes": {
      "types": "./dist/themes.d.ts",
      "import": "./dist/themes.js"
    },
    "./bridges": {
      "types": "./dist/bridges.d.ts",
      "import": "./dist/bridges.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com"
}

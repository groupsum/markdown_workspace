{
  "version": "1.2.4",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "dist",
    "src/styles",
    "README.md"
  ],
  "name": "@mdwrk/ui-tokens",
  "description": "Shared CSS tokens, markdown class names, and theme mapping helpers for MdWrk packages and applications.",
  "sideEffects": [
    "./src/styles/*.css"
  ],
  "keywords": [
    "markdown-workspace",
    "shared",
    "css",
    "tokens",
    "themes"
  ],
  "dependencies": {
    "@mdwrk/theme-contract": "^1.1.3"
  },
  "scripts": {
    "build:deps": "npm run build -w @mdwrk/theme-contract",
    "build": "npm run build:deps && tsc -p tsconfig.json",
    "typecheck": "npm run build:deps && tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "npm run build && node ./tests/prepare-workspace-links.mjs && node ./tests/run-smoke.mjs",
    "prepack": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./classes": {
      "types": "./dist/classes.d.ts",
      "import": "./dist/classes.js"
    },
    "./theme-map": {
      "types": "./dist/theme-map.d.ts",
      "import": "./dist/theme-map.js"
    },
    "./styles/index.css": "./src/styles/index.css",
    "./styles/root.css": "./src/styles/root.css",
    "./styles/markdown.css": "./src/styles/markdown.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com"
}

{
  "version": "1.0.4",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "name": "@mdwrk/testing",
  "description": "Shared browser and React test helpers for MdWrk packages.",
  "sideEffects": [
    "./dist/vitest-setup.js"
  ],
  "keywords": [
    "markdown-workspace",
    "shared",
    "testing",
    "vitest",
    "deprecated",
    "legacy-bridge",
    "extracted-repo"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "npm run typecheck",
    "prepack": "npm run build",
    "postinstall": "node ../../../tools/release/warn-deprecated-package.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./timing": {
      "types": "./dist/timing.d.ts",
      "import": "./dist/timing.js"
    },
    "./vitest-setup": {
      "types": "./dist/vitest-setup.d.ts",
      "import": "./dist/vitest-setup.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/groupsum/mdwrk",
    "directory": "packages/shared/testing"
  },
  "bugs": {
    "url": "https://github.com/groupsum/mdwrk/issues"
  },
  "private": true
}

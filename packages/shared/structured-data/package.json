{
  "name": "@mdwrk/structured-data",
  "version": "0.1.5",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": [
    "structured-data",
    "schema.org",
    "json-ld",
    "seo",
    "aeo",
    "aieo",
    "deprecated",
    "legacy-bridge",
    "extracted-repo"
  ],
  "description": "Reusable Schema.org and JSON-LD builders for MdWrk apps, packages, public content, and discovery surfaces.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "npm run build && node tests/run-smoke.mjs",
    "prepack": "npm run build",
    "postinstall": "node ../../../tools/release/warn-deprecated-package.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/groupsum/mdwrk-pages",
    "directory": "packages/shared/structured-data"
  },
  "bugs": {
    "url": "https://github.com/groupsum/mdwrk-pages/issues"
  },
  "private": true
}

{
  "name": "@mdwrk/page-template-demo-content-pack",
  "version": "0.1.2",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "content",
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": [
    "mdwrk",
    "lander",
    "content-pack",
    "page-templates",
    "demo",
    "deprecated",
    "legacy-bridge",
    "extracted-repo"
  ],
  "description": "Example MdWrk content pack demonstrating page-template presets as authored starter content.",
  "dependencies": {
    "@mdwrk/lander-content-contract": "^0.1.3",
    "@mdwrk/lander-page-template-presets": "^0.1.1",
    "@mdwrk/lander-page-templates": "^0.1.2"
  },
  "scripts": {
    "build": "node ./scripts/generate-markdown-pages.mjs && npm run build -w @mdwrk/lander-page-template-presets && tsc -p tsconfig.json",
    "typecheck": "node ./scripts/generate-markdown-pages.mjs && npm run build -w @mdwrk/lander-page-template-presets && tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "npm run build && node ./tests/run-smoke.mjs",
    "prepack": "npm run build",
    "postinstall": "node ../../../tools/release/warn-deprecated-package.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/groupsum/mdwrk-pages",
    "directory": "packages/content/page-template-demo-content-pack"
  },
  "bugs": {
    "url": "https://github.com/groupsum/mdwrk-pages/issues"
  }
}

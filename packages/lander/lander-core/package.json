{
  "name": "@mdwrk/lander-core",
  "version": "0.1.5",
  "type": "module",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "keywords": [
    "lander",
    "compiler",
    "seo",
    "portable",
    "deprecated",
    "legacy-bridge",
    "extracted-repo"
  ],
  "description": "Portable compiler and diagnostics for product landing site content.",
  "dependencies": {
    "@mdwrk/lander-content-contract": "^0.1.3"
  },
  "scripts": {
    "build": "npm run build -w @mdwrk/lander-content-contract && tsc -p tsconfig.json",
    "typecheck": "npm run build -w @mdwrk/lander-content-contract && tsc --noEmit -p tsconfig.json",
    "lint": "npm run typecheck",
    "test": "npm run build && node ./tests/run-smoke.mjs && node ./tests/performance-budget.test.mjs",
    "prepack": "npm run build",
    "postinstall": "node ../../../tools/release/warn-deprecated-package.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./version": {
      "types": "./dist/version.d.ts",
      "import": "./dist/version.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jacob Stewart <jacob@swarmauri.com>",
  "homepage": "https://mdwrk.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/groupsum/mdwrk-pages",
    "directory": "packages/lander/lander-core"
  },
  "bugs": {
    "url": "https://github.com/groupsum/mdwrk-pages/issues"
  },
  "private": true
}
